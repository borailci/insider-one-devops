@startuml deployment
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Deployment.puml

title CI/CD pipeline — code to signed image to live cluster

LAYOUT_LEFT_RIGHT()

Person(dev, "Developer", "git push to main / PR")

Deployment_Node(github, "github.com", "SaaS") {
  Container(repo, "borailci/insider-one-devops", "Repo")
  Container(actions, "GitHub Actions", "CI runner (ubuntu-latest)")
  Container(oidc, "OIDC issuer", "token.actions.githubusercontent.com")
}

Deployment_Node(pipeline, "Workflow: ci.yml", "Pipeline job sequence") {
  Container(lint, "lint", "go vet + go fmt + golangci-lint")
  Container(test, "test", "go test ./...")
  Container(gitleaks, "gitleaks", "Secret scan with custom rule")
  Container(helmval, "helm-validate", "helm lint + helm template")
  Container(build, "build-scan-push", "Buildx multi-arch (amd64+arm64); Trivy → SBOM via Syft → cosign keyless sign → cosign verify gate")
  Container(kindjob, "integration-test", "kind cluster + helm install + helm test (catches install-order bugs)")
  Container(deploy, "deploy", "Assume role via OIDC, run kubectl set image via SSM")
}

Deployment_Node(ghcr, "ghcr.io", "OCI registry") {
  Container(image, "insider-one-devops", "Multi-arch image + signature + SBOM (CycloneDX)")
}

Deployment_Node(aws, "AWS eu-north-1", "Cloud") {
  Container(role, "IAM role", "insider-one-devops-github-deploy (OIDC trust, sub=main+prod env)")
  Deployment_Node(ec2, "EC2 t3.medium", "Amazon Linux 2023") {
    Container(mk, "minikube", "Single-node k8s. Runs ingress-nginx, app, kube-prometheus-stack, Kyverno.")
  }
}

Rel(dev, repo, "git push")
Rel(repo, actions, "workflow_run on push/PR")
Rel(actions, oidc, "Request OIDC token")
Rel(oidc, role, "AssumeRoleWithWebIdentity (sub matches main or prod env)")

Rel(actions, lint, "")
Rel(lint, test, "")
Rel(test, gitleaks, "")
Rel(gitleaks, helmval, "")
Rel(helmval, build, "")
Rel(build, image, "push + sign + attach SBOM")
Rel(build, kindjob, "")
Rel(kindjob, deploy, "main only")
Rel(deploy, role, "Assume")
Rel(role, mk, "ssm:SendCommand → kubectl set image")
Rel(mk, image, "Pull on rollout")

SHOW_LEGEND()
@enduml
